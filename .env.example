OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_API_KEY=your_google_api_key
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Tor SOCKS proxy (used for .onion access)
TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051
TOR_PASSWORD=

# GitHub (required for dorking & code search)
GITHUB_TOKEN=

# Defaults
DEFAULT_MODEL=gpt4o

# CORS (comma-separated origins). Use * only for local dev.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Uvicorn workers (used in docker-compose)
UVICORN_WORKERS=2

# Scraping configuration
MAX_SCRAPE_CHARS=1200
CREDENTIAL_SCRAPE_CHARS=50000

# ── Credential Hunting Feature Toggles ──────────────────────────────
# Each opt-in feature is disabled by default for safety
ENABLE_LIVE_VERIFICATION=false
ENABLE_BREACH_LOOKUP=false
ENABLE_DB_DISCOVERY=false
ENABLE_ML_FILTERING=true
ENABLE_GITHUB_DORKING=false

# ── Breach Lookup API Keys ──────────────────────────────────────────
# Provide keys for the services you want to use; leave blank to skip
HIBP_API_KEY=
SNUSBASE_API_KEY=
DEHASHED_API_KEY=
DEHASHED_EMAIL=admin@example.com
INTELX_API_KEY=
LEAKLOOKUP_API_KEY=
WELEAKINFO_API_KEY=
SCYLLA_API_KEY=

# ── Rate Limiting ───────────────────────────────────────────────────
# Milliseconds between breach API calls to prevent rate-ban
BREACH_RATE_LIMIT_MS=1000

# ── Database Discovery ──────────────────────────────────────────────
BINARYEDGE_API_KEY=

# Telegram API Configuration (Optional - for Telegram Log Scraper)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
GRAYHATWARFARE_API_KEY=

# ── Credential Pattern Engine ───────────────────────────────────────
CREDENTIAL_MIN_CONFIDENCE=medium
# CREDENTIAL_CATEGORIES=api_keys,cloud_credentials,payment
